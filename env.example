# =============================================================================
# .env - Configuración para hayahora_monitor.sh
# Copia este fichero como .env y rellena los valores.
# =============================================================================

# URL base de tu instancia de Mattermost (sin / final)
MATTERMOST_URL=https://mattermost.example.com

# Token de bot o token personal con permisos para publicar
MATTERMOST_TOKEN=tu-token-aqui

# ID del canal donde publicar (no el nombre, el ID interno)
# Lo puedes obtener desde la interfaz o la API de Mattermost
MATTERMOST_CHANNEL_ID=abc123channelid

# (Opcional) URL de la API de hayahora.futbol
# API_URL=https://hayahora.futbol/estado/data.json

# (Opcional) Timeout para curl en segundos
# CURL_TIMEOUT=15

# (Opcional) Porcentaje mínimo de IPs bloqueadas en un ISP para considerar
# bloqueo real. Por defecto 50%. Cuando LaLiga bloquea de verdad, >90% de las
# IPs se bloquean simultáneamente; las IPs sueltas son ruido residual.
# BLOCK_THRESHOLD_PCT=50

# (Opcional) URL de push de Uptime Kuma. Si se define, el script enviará un
# GET a esta URL al finalizar con éxito como heartbeat de monitorización.
# IMPORTANTE: entrecomilla el valor si la URL contiene '&' o ';', de lo
# contrario bash interpretará esos caracteres al hacer source de este fichero.
# UPTIME_KUMA_PUSH_URL="https://uptime.example.com/api/push/abc123?status=up&msg=OK&ping="

# (Opcional) URL de Ntfy para notificar fallos del script (indica el paso y
# motivo del fallo). Si no se define, no se envían notificaciones de error.
# NTFY_URL=https://ntfy.sh/mi-topic-privado
# (Opcional) Token Bearer para Ntfy si el topic está protegido.
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxxxxxxxxx
